# FairLens Backend — Environment Variables
# =========================================
# Copy this file to .env and fill in your actual keys
# NEVER commit the real .env file to GitHub!

# ── Gemini API ─────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Firebase ──────────────────────────────
# Path to your Firebase service account JSON file
# Get from: Firebase Console → Project Settings → Service Accounts → Generate Key
FIREBASE_KEY_PATH=path/to/your/firebase-service-account.json
